# ──────────────────────────────────────────────────────────
# JanSamadhan — Docker Environment Variables
# Copy this file as .env and fill in real values
# ──────────────────────────────────────────────────────────

# DATABASE
DB_ROOT_PASSWORD=your_root_password
DB_NAME=jansamadhan
DB_USER=jan_user
DB_PASSWORD=your_db_password

# JWT — generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_128_CHAR_SECRET

# GOOGLE OAUTH 2.0
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://your-domain.com/api/auth/google/callback

# CLOUDINARY
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# FRONTEND URL (used for CORS)
FRONTEND_URL=http://your-domain.com

# EMAIL (Gmail SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_16_char_app_password
EMAIL_FROM="JanSamadhan" <your_email@gmail.com>

# CLIENT BUILD ARGS
VITE_API_URL=/api
VITE_SOCKET_URL=
