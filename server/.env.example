# ──────────────────────────────────────────────────────────
# JanSamadhan Backend — Environment Variables Template
# Copy this file to .env and fill in all values
# NEVER commit .env to git
# ──────────────────────────────────────────────────────────

# SERVER
PORT=5000
NODE_ENV=development

# DATABASE (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=<your_mysql_user>
DB_PASSWORD=<your_mysql_password>
DB_NAME=jansamadhan

# JWT
JWT_SECRET=<generate_with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))">
JWT_EXPIRES_IN=7d
JWT_ADMIN_EXPIRES_IN=1h

# GOOGLE OAUTH 2.0
# Get from: https://console.cloud.google.com -> APIs & Services -> Credentials
GOOGLE_CLIENT_ID=<your_google_client_id>
GOOGLE_CLIENT_SECRET=<your_google_client_secret>
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# CLOUDINARY (Image Uploads)
# Get from: https://cloudinary.com -> Dashboard
CLOUDINARY_CLOUD_NAME=<your_cloud_name>
CLOUDINARY_API_KEY=<your_api_key>
CLOUDINARY_API_SECRET=<your_api_secret>

# FRONTEND URL (for CORS + OAuth redirect)
FRONTEND_URL=http://localhost:5173

# RATE LIMITING
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200

# EMAIL (Gmail SMTP) — required for password reset emails
# Generate an App Password: https://myaccount.google.com/apppasswords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=<your_gmail@gmail.com>
EMAIL_PASS=<your_16_char_app_password>
EMAIL_FROM="JanSamadhan" <your_gmail@gmail.com>

# SUPER ADMIN SEED — used only by: node scripts/linkPassword.js
# Change these before running the script. Never share or commit real passwords.
SUPER_ADMIN_EMAIL=superadmin@jansamadhan.com
SUPER_ADMIN_PASSWORD=Admin@1234
SUPER_ADMIN_NAME=Super Admin
